# ── Backend (Python / FastAPI) ──
DATABASE_URL=                      # PostgreSQL (leave blank for SQLite dev)
DATABASE_POOLED_URL=               # Pooled URL for Neon/pgbouncer
SECRET_KEY=                        # JWT signing key (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
FERNET_KEY=                        # Encryption key for FB tokens (separate from SECRET_KEY)
CRON_SECRET=                       # Secret for cron endpoint auth
FACEBOOK_ACCESS_TOKEN=             # FB Page access token
FACEBOOK_PAGE_ID=                  # FB Page ID
FB_WEBHOOK_VERIFY_TOKEN=           # Webhook verification token
FACEBOOK_APP_SECRET=               # FB App secret for webhook signature verification
REDIS_URL=                         # Redis connection string
DEBUG=False                        # Enable debug mode
LOG_LEVEL=INFO                     # Logging level
BOT_INTERVAL_SECONDS=10            # Bot polling interval
START_BOT=True                     # Auto-start bot on app boot

# ── Telegram Admin Bot ──
TELEGRAM_BOT_TOKEN=                # Telegram bot token for admin notifications
TELEGRAM_ADMIN_IDS=                # Comma-separated Telegram user IDs
TELEGRAM_WEBHOOK_SECRET=           # Telegram webhook secret

# ── AI ──
OPENAI_API_KEY=                    # OpenAI API key (optional)
OPENAI_BASE_URL=                   # OpenAI base URL (optional)

# ── Frontend (Next.js) ──
# These go in fb_dashboard/frontend/.env.local:
# NEXT_PUBLIC_API_HOST=https://api.smart-link.ly
# NEXT_PUBLIC_DOMAIN=https://bot.smart-link.ly
