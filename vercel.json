{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/healthz", "destination": "/api/index.py" },
    { "source": "/webhook", "destination": "/api/index.py" }
  ],
  "functions": {
    "api/index.py": { "maxDuration": 30 }
  },
  "buildCommand": null,
  "crons": [
    { "path": "/api/cron/bot-cycle", "schedule": "0 6 * * *" }
    # ponytail: hobby plan limits to 1x/day. Upgrade to Pro for */5 polling.
  ]
}
