{
  "framework": "fastapi",
  "regions": ["iad1"],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/static/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "pythonVersion": "3.12",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 512,
      "excludeFiles": "{__pycache__/**,**/.pytest_cache/**,tests/**,mobile/**,docs/**,e2e_artifacts/**,.playwright-mcp/**,*.md,*.db,botlogo.png,alembic/**}"
    }
  }
}
